                    <span class="block font-black text-sm md:text-lg text-slate-500">기초</span>
                </button>
                <button onclick="updateYear(3)" id="year-btn-3" class="year-btn bg-white border border-slate-200 rounded-2xl p-3 md:p-5 text-center hover:border-blue-300 transition-all">
                    <span class="block text-[10px] md:text-xs font-black text-slate-400 mb-1">3학년</span>
                    <span class="block font-black text-sm md:text-lg text-slate-500">심화</span>
                </button>
                <button onclick="updateYear(4)" id="year-btn-4" class="year-btn bg-white border border-slate-200 rounded-2xl p-3 md:p-5 text-center hover:border-blue-300 transition-all">
                    <span class="block text-[10px] md:text-xs font-black text-slate-400 mb-1">4학년</span>
                    <span class="block font-black text-sm md:text-lg text-slate-500">도약</span>
                </button>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <!-- 교육과정 리스트 -->
                <div class="bg-white rounded-3xl p-6 md:p-8 border border-slate-200 shadow-sm">
                    <h3 class="text-base font-black text-slate-800 mb-6 flex items-center gap-2">
                        <i class="fa-solid fa-book-open text-blue-600"></i> 중점 이수 과목 및 활동
                    </h3>
                    <div id="course-list" class="space-y-6 relative border-l-2 border-slate-100 ml-2 pl-6">
                        <!-- JS로 동적 렌더링 -->
                    </div>
                </div>

                <!-- 역량 레이더 차트 -->
                <div class="bg-white rounded-3xl p-6 md:p-8 border border-slate-200 shadow-sm">
                    <h3 class="text-base font-black text-slate-800 mb-6 flex items-center gap-2">
                        <i class="fa-solid fa-chart-pie text-blue-600"></i> 학년별 예상 역량 지표
                    </h3>
                    <div class="w-full h-64 md:h-80 relative flex justify-center items-center">
                        <canvas id="radarChart"></canvas>
                    </div>
                </div>
            </div>
        </section>

        <!-- ==========================================
             2. 창업 아이템 탭
        ========================================== -->
        <section id="tab-startup" class="tab-content max-w-6xl mx-auto">
            <header class="mb-6 md:mb-8">
                <h2 class="text-2xl font-black text-slate-900 mb-2">학습 연계 창업 비즈니스 모델</h2>
                <p class="text-sm text-slate-500">교수님 제안을 반영하여 대학 생활과 시너지를 내는 창업 아이템 구상안입니다.</p>
            </header>

            <!-- 히어로 배너 -->
            <div class="bg-slate-900 rounded-3xl p-8 md:p-12 text-white relative overflow-hidden shadow-xl mb-6">
                <div class="relative z-10">
                    <span class="px-3 py-1 bg-blue-600 text-white rounded-full text-[10px] font-black tracking-wider mb-4 inline-block">STARTUP IDEA</span>
                    <h3 class="text-3xl md:text-4xl font-black mb-4">"GNU Livestock AX-Navigator"</h3>
                    <p class="text-slate-300 md:text-lg leading-relaxed font-medium max-w-2xl">
                        축산 전공 학생들의 <strong class="text-white">실습 경험과 데이터</strong>를 가치 있게 만드는 '전공 맞춤형 커리어 데이터 매니지먼트 플랫폼'.<br>
                        학생에게는 최적의 진로를, 산업계에는 검증된 인재와 데이터를 제공합니다.
                    </p>
                </div>
                <i class="fa-solid fa-rocket absolute -bottom-10 -right-10 text-[150px] md:text-[250px] text-white opacity-5"></i>
            </div>

            <!-- 핵심 BM 3가지 -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="bg-white p-6 md:p-8 rounded-3xl border border-slate-200 shadow-sm hover:-translate-y-1 transition-transform">
                    <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center text-xl mb-4">
                        <i class="fa-solid fa-database"></i>
                    </div>
                    <h4 class="font-black text-lg mb-2">실습 데이터 뱅크</h4>
                    <p class="text-sm text-slate-500 leading-relaxed">전공생들이 학내 농장에서 실습하며 수집한 가축 환경/생체 데이터를 익명화하여 연구소에 제공하는 데이터 허브.</p>
                </div>
                <div class="bg-white p-6 md:p-8 rounded-3xl border border-slate-200 shadow-sm hover:-translate-y-1 transition-transform">
                    <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-2xl flex items-center justify-center text-xl mb-4">
                        <i class="fa-solid fa-route"></i>
                    </div>
                    <h4 class="font-black text-lg mb-2">맞춤형 진로 매칭</h4>
                    <p class="text-sm text-slate-500 leading-relaxed">개인의 과목 이수 현황과 실습 숙련도(AX 역량)를 AI가 분석하여, 스마트팜 취업 및 창업의 최적 경로를 추천.</p>
                </div>
                <div class="bg-white p-6 md:p-8 rounded-3xl border border-slate-200 shadow-sm hover:-translate-y-1 transition-transform">
                    <div class="w-12 h-12 bg-rose-50 text-rose-600 rounded-2xl flex items-center justify-center text-xl mb-4">
                        <i class="fa-solid fa-users-gear"></i>
                    </div>
                    <h4 class="font-black text-lg mb-2">축산 AX 네트워크</h4>
                    <p class="text-sm text-slate-500 leading-relaxed">전국 축산 관련 대학생들이 모여 스마트 축산 기술을 공유하고, 선배 창업가들과 멘토링을 맺는 커뮤니티.</p>
                </div>
            </div>
        </section>

        <!-- ==========================================
             3. 실무 진단 탭 (AX 시뮬레이션)
        ========================================== -->
        <section id="tab-analysis" class="tab-content max-w-6xl mx-auto">
            <header class="mb-6 md:mb-8">
                <h2 class="text-2xl font-black text-slate-900 mb-2">가축 생체 데이터 AI 분석 (실습용)</h2>
                <p class="text-sm text-slate-500">실제 스마트 농장에서 데이터를 수집하고 AI가 상태를 판별하는 과정을 체험합니다.</p>
            </header>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- 실시간 차트 -->
                <div class="lg:col-span-2 bg-white rounded-3xl p-6 md:p-8 border border-slate-200 shadow-sm">
                    <div class="flex justify-between items-center mb-6">
                        <h3 class="text-base font-black text-slate-800 flex items-center gap-2">
                            <span class="w-2 h-2 bg-rose-500 rounded-full animate-pulse"></span> 실시간 개체 체온 변화 스트림
                        </h3>
                    </div>
                    <div class="w-full h-64 md:h-80 relative">
                        <canvas id="streamChart"></canvas>
                    </div>
                </div>

                <!-- 입력 및 결과 패널 -->
                <div class="flex flex-col gap-6">
                    <div class="bg-white rounded-3xl p-6 md:p-8 border border-slate-200 shadow-sm">
                        <h3 class="text-sm font-black text-slate-800 mb-4 flex items-center gap-2">
                            <i class="fa-solid fa-keyboard text-blue-600"></i> 센서 데이터 입력
                        </h3>
                        <div class="mb-4">
                            <label class="block text-xs font-bold text-slate-500 mb-2">개체 측정 온도 (°C)</label>
                            <input type="number" id="temp-input" value="38.5" step="0.1" class="w-full bg-slate-50 border border-slate-200 text-slate-900 font-bold rounded-xl px-4 py-3 outline-none focus:border-blue-500 focus:bg-white transition-all text-lg">
                        </div>
                        <button onclick="analyzeHealth()" class="w-full gnu-bg text-white font-black rounded-xl py-3 shadow-md hover:opacity-90 active:scale-95 transition-all">
                            AI 판별 실행
                        </button>
                    </div>

                    <div id="status-card" class="flex-1 bg-slate-800 rounded-3xl p-6 md:p-8 text-center text-white flex flex-col justify-center items-center transition-all duration-300">
                        <i id="status-icon" class="fa-solid fa-circle-check text-5xl text-emerald-400 mb-4"></i>
                        <h3 id="status-title" class="text-2xl font-black text-emerald-400 mb-2">정상 상태</h3>
                        <p id="status-desc" class="text-sm text-slate-300">현재 입력된 데이터는 가축의 정상 대사 범위 내에 있습니다.</p>
                    </div>
                </div>
            </div>
        </section>

    </main>

    <script>
        // ==========================================
        // 1. 학년별 데이터 (로드맵 & 차트용)
        // ==========================================
        const roadmapData = {
            1: {
                skills: [30, 10, 20, 15, 20],
                courses: [
                    { title: "전공: 축산학개론", desc: "축산업의 역사, 가치 및 미래 스마트 축산의 방향성 이해" },
                    { title: "AX: 파이썬 코딩 입문", desc: "데이터 분석을 위한 프로그래밍 기초 및 논리적 사고력 배양" },
                    { title: "활동: 학과 소모임 가입", desc: "전공 관련 동아리 활동을 통한 기초 실무 경험 및 네트워킹" }
                ]
            },
            2: {
                skills: [55, 40, 45, 30, 50],
                courses: [
                    { title: "전공: 가축생리학 & 번식학", desc: "정밀 사양 관리를 위한 가축의 신체/대사 메커니즘 심화" },
                    { title: "AX: 스마트 ICT 기기 제어", desc: "환경 제어 센서(온습도) 원리 이해 및 아두이노 데이터 수집" },
                    { title: "자격증: 빅데이터분석기사", d: "데이터 전처리 및 기초 통계 역량 확보를 위한 필기 준비" }
                ]
            },
            3: {
                skills: [80, 70, 75, 60, 80],
                courses: [
                    { title: "전공: 가축영양학 & 사료학", desc: "개체별 데이터를 바탕으로 한 최적 영양소 설계 및 급이 모델" },
                    { title: "AX: 머신러닝 & 질병 예찰", desc: "수집된 행동/체온 데이터를 활용한 이상 징후 감지 AI 모델링" },
                    { title: "현장: 스마트 축산 캡스톤", desc: "실제 농가의 문제를 해결하는 팀 단위 문제해결형 프로젝트" }
                ]
            },
            4: {
                skills: [95, 90, 95, 90, 95],
                courses: [
                    { title: "전공: 축산경영학", desc: "데이터 기반 농장 생산성 예측 및 경제성 분석 시뮬레이션" },
                    { title: "창업: 비즈니스 모델(BM) 구축", desc: "AX-Navigator 아이템 구체화 및 창업 지원사업계획서 작성" },
                    { title: "졸업: AX 통합 관제 솔루션", desc: "4년간의 역량을 집약한 모바일 기반 농장 관리 대시보드 개발" }
                ]
            }
        };

        // 전역 차트 객체
        let radarChart = null;
        let streamChart = null;
        let isEmergency = false; // 실무 진단 상태

        // ==========================================
        // 2. 초기화 (DOM 로드 후 실행)
        // ==========================================
        document.addEventListener('DOMContentLoaded', () => {
            initRadarChart();
            initStreamChart();
            updateYear(1); // 1학년 기본 표시
        });

        // ==========================================
        // 3. UI 조작 로직 (탭 & 학년 전환)
        // ==========================================
        function changeTab(tabId) {
            // 버튼 상태 변경
            document.querySelectorAll('.nav-btn').forEach(btn => btn.classList.remove('active', 'bg-[#004ea2]', 'text-white'));
            document.querySelectorAll('.nav-btn i').forEach(icon => icon.classList.remove('text-white'));
            
            const activeBtn = document.getElementById('btn-' + tabId);
            activeBtn.classList.add('active');
            activeBtn.querySelector('i').classList.add('text-white');

            // 콘텐츠 전환
            document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
            document.getElementById('tab-' + tabId).classList.add('active');
        }

        function updateYear(year) {
            // 버튼 스타일 업데이트
            document.querySelectorAll('.year-btn').forEach(btn => {
                btn.classList.remove('border-blue-600', 'shadow-md');
                btn.classList.add('border-slate-200');
                btn.querySelectorAll('span')[0].classList.replace('text-blue-600', 'text-slate-400');
                btn.querySelectorAll('span')[1].classList.replace('text-slate-900', 'text-slate-500');
            });
            
            const activeBtn = document.getElementById('year-btn-' + year);
            activeBtn.classList.add('border-blue-600', 'shadow-md');
            activeBtn.classList.remove('border-slate-200');
            activeBtn.querySelectorAll('span')[0].classList.replace('text-slate-400', 'text-blue-600');
            activeBtn.querySelectorAll('span')[1].classList.replace('text-slate-500', 'text-slate-900');

            // 커리큘럼 리스트 업데이트
            const listContainer = document.getElementById('course-list');
            listContainer.innerHTML = '';
            roadmapData[year].courses.forEach(course => {
                listContainer.innerHTML += `
                    <div class="relative mb-5 last:mb-0">
                        <div class="absolute -left-[31px] top-1 w-3 h-3 bg-white border-2 border-blue-600 rounded-full"></div>
                        <h4 class="font-bold text-slate-800 text-sm md:text-base">${course.title}</h4>
                        <p class="text-xs text-slate-500 mt-1">${course.desc || course.d}</p>
                    </div>
                `;
            });

            // 레이더 차트 데이터 업데이트
            if (radarChart) {
                radarChart.data.datasets[0].data = roadmapData[year].skills;
                radarChart.update();
            }
        }

        // ==========================================
        // 4. 차트 생성 및 구동 로직
        // ==========================================
        function initRadarChart() {
            const ctx = document.getElementById('radarChart').getContext('2d');
            Chart.defaults.font.family = "'Noto Sans KR', sans-serif";
            
            radarChart = new Chart(ctx, {
                type: 'radar',
                data: {
                    labels: ['전공이해도', 'AI/코딩', '데이터해석', '경영전략', '실습숙련도'],
                    datasets: [{
                        label: '역량 지수',
                        data: roadmapData[1].skills,
                        backgroundColor: 'rgba(0, 78, 162, 0.2)',
                        borderColor: '#004ea2',
                        borderWidth: 2,
                        pointBackgroundColor: '#004ea2',
                        pointBorderColor: '#fff',
                        pointHoverBackgroundColor: '#fff',
                        pointHoverBorderColor: '#004ea2'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        r: {
                            angleLines: { color: 'rgba(0, 0, 0, 0.05)' },
                            grid: { color: 'rgba(0, 0, 0, 0.05)' },
                            pointLabels: { font: { size: 12, weight: 'bold' }, color: '#475569' },
                            ticks: { display: false, min: 0, max: 100 }
                        }
                    },
                    plugins: { legend: { display: false } }
                }
            });
        }

        function initStreamChart() {
            const ctx = document.getElementById('streamChart').getContext('2d');
            
            streamChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: Array.from({length: 20}, (_, i) => i + 's'),
                    datasets: [{
                        label: '온도 (°C)',
                        data: Array.from({length: 20}, () => 38.5),
                        borderColor: '#004ea2',
                        backgroundColor: 'rgba(0, 78, 162, 0.1)',
                        borderWidth: 3,
                        tension: 0.4,
                        fill: true,
                        pointRadius: 0, // 점 숨기기
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    animation: { duration: 0 }, // 부드러운 스트리밍을 위해 애니메이션 제거
                    scales: {
                        y: { min: 37, max: 41, grid: { color: 'rgba(0,0,0,0.05)' } },
                        x: { display: false } // X축 숨기기
                    },
                    plugins: { legend: { display: false } }
                }
            });

            // 1초 단위로 데이터 스트리밍 시뮬레이션
            setInterval(() => {
                if(!streamChart) return;
                const data = streamChart.data.datasets[0].data;
                data.shift(); // 첫 번째 값 제거
                
                const baseTemp = isEmergency ? 40.2 : 38.5; // 베이스 온도
                const noise = (Math.random() * 0.4) - 0.2; // 약간의 노이즈 추가
                
                data.push(baseTemp + noise); // 새 값 추가
                streamChart.update();
            }, 1000);
        }

        function analyzeHealth() {
            const tempVal = parseFloat(document.getElementById('temp-input').value);
            const card = document.getElementById('status-card');
            const icon = document.getElementById('status-icon');
            const title = document.getElementById('status-title');
            const desc = document.getElementById('status-desc');

            if (tempVal >= 39.5) {
                // 이상 상태
                isEmergency = true;
                if(streamChart) streamChart.data.datasets[0].borderColor = '#e11d48'; // 빨간색
                if(streamChart) streamChart.data.datasets[0].backgroundColor = 'rgba(225, 29, 72, 0.1)';
                
                card.className = "flex-1 bg-rose-900 rounded-3xl p-6 md:p-8 text-center text-white flex flex-col justify-center items-center transition-all duration-300 border-2 border-rose-500 shadow-xl scale-105 md:scale-100";
                icon.className = "fa-solid fa-triangle-exclamation text-5xl text-rose-400 mb-4 animate-bounce";
                title.className = "text-2xl font-black text-rose-400 mb-2";
                title.innerText = "주의 (경고)";
                desc.innerText = "입력된 온도가 임계치를 초과했습니다! 축사 환기 시스템을 점검하고 개체의 상태를 즉시 확인하세요.";
            } else {
                // 정상 상태
                isEmergency = false;
                if(streamChart) streamChart.data.datasets[0].borderColor = '#004ea2'; // 파란색
                if(streamChart) streamChart.data.datasets[0].backgroundColor = 'rgba(0, 78, 162, 0.1)';
                
                card.className = "flex-1 bg-slate-800 rounded-3xl p-6 md:p-8 text-center text-white flex flex-col justify-center items-center transition-all duration-300";
                icon.className = "fa-solid fa-circle-check text-5xl text-emerald-400 mb-4";
                title.className = "text-2xl font-black text-emerald-400 mb-2";
                title.innerText = "정상 상태";
                desc.innerText = "현재 입력된 데이터는 가축의 정상 대사 범위 내에 있습니다.";
            }
        }
    </script>
</body>
</html>
