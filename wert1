<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GNU 축산과학부 AX 커리어 설계 플랫폼</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Pretendard:wght@400;600;700;800;900&display=swap');
        body { font-family: 'Pretendard', sans-serif; background-color: #f8fafc; overflow: hidden; }
        .sidebar-item.active { background-color: #004ea2; color: white; box-shadow: 0 4px 12px rgba(0, 78, 162, 0.2); }
        .card-glass { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.2); }
        .gnu-blue { color: #004ea2; }
        .gnu-bg { background-color: #004ea2; }
        .animate-float { animation: float 3s ease-in-out infinite; }
        @keyframes float { 0% { transform: translateY(0px); } 50% { transform: translateY(-10px); } 100% { transform: translateY(0px); } }
        .custom-scroll::-webkit-scrollbar { width: 6px; }
        .custom-scroll::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
    </style>
</head>
<body class="text-slate-900">

    <div class="flex h-screen w-full">
        <!-- Sidebar -->
        <aside class="w-72 bg-white border-r border-slate-200 flex flex-col shrink-0 z-50">
            <div class="p-8">
                <div class="flex items-center gap-3 mb-8">
                    <div class="w-12 h-12 gnu-bg rounded-2xl flex items-center justify-center text-white text-2xl shadow-lg animate-float">
                        <i class="fa-solid fa-seedling"></i>
                    </div>
                    <div>
                        <h1 class="text-xl font-black tracking-tighter italic">GNU AX Path</h1>
                        <p class="text-[10px] font-bold text-blue-500 uppercase">Animal Science Career</p>
                    </div>
                </div>

                <div class="space-y-2">
                    <button onclick="showSection('roadmap', this)" class="sidebar-item active w-full flex items-center gap-3 px-5 py-3.5 rounded-xl text-sm font-bold text-left transition-all">
                        <i class="fa-solid fa-route"></i> 4개년 로드맵
                    </button>
                    <button onclick="showSection('startup', this)" class="sidebar-item w-full flex items-center gap-3 px-5 py-3.5 rounded-xl text-sm font-bold text-left text-slate-500 hover:bg-slate-50 transition-all">
                        <i class="fa-solid fa-lightbulb"></i> 창업 아이템 (BM)
                    </button>
                    <button onclick="showSection('analysis', this)" class="sidebar-item w-full flex items-center gap-3 px-5 py-3.5 rounded-xl text-sm font-bold text-left text-slate-500 hover:bg-slate-50 transition-all">
                        <i class="fa-solid fa-stethoscope"></i> AI 실무 진단 (실습)
                    </button>
                </div>
            </div>

            <div class="mt-auto p-8 border-t border-slate-100">
                <div class="bg-blue-50 rounded-2xl p-4">
                    <p class="text-[11px] font-black text-blue-700 mb-1">나의 현재 레벨</p>
                    <div class="flex items-center justify-between text-[10px] text-blue-500 font-bold mb-2">
                        <span>신입생 (Level 1)</span>
                        <span>15%</span>
                    </div>
                    <div class="w-full bg-blue-200 h-1.5 rounded-full overflow-hidden">
                        <div class="bg-blue-600 h-full w-[15%]"></div>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col overflow-hidden">
            <!-- Header -->
            <header class="h-20 bg-white/80 backdrop-blur-md border-b border-slate-100 px-10 flex items-center justify-between shrink-0">
                <h2 id="section-title" class="text-xl font-black text-slate-800 tracking-tight italic">4개년 교육 로드맵</h2>
                <div class="flex items-center gap-4">
                    <div class="text-right">
                        <p class="text-xs font-black text-slate-900 leading-none">26학번 신입생</p>
                        <p class="text-[10px] text-slate-400 font-medium mt-1">Gyeongsang National Univ.</p>
                    </div>
                    <div class="w-10 h-10 rounded-full gnu-bg flex items-center justify-center text-white font-black text-sm border-2 border-white shadow-md">G</div>
                </div>
            </header>

            <!-- Scrollable Area -->
            <div id="content-area" class="flex-1 overflow-y-auto p-10 custom-scroll">
                
                <!-- Section: Roadmap -->
                <div id="section-roadmap" class="section-content space-y-8 block animate-in fade-in duration-500">
                    <div class="grid grid-cols-4 gap-4">
                        <button onclick="updateRoadmap(1, this)" class="year-card bg-white p-6 rounded-[2rem] border-2 border-blue-600 shadow-xl transition-all scale-105">
                            <span class="text-[10px] font-black text-blue-600 uppercase mb-2 block">Stage 01</span>
                            <h3 class="text-lg font-black">1학년: 탐색</h3>
                            <p class="text-[11px] text-slate-400 mt-1">AX 기초 및 전공 입문</p>
                        </button>
                        <button onclick="updateRoadmap(2, this)" class="year-card bg-white p-6 rounded-[2rem] border border-slate-100 hover:border-blue-300 shadow-sm transition-all">
                            <span class="text-[10px] font-black text-slate-400 uppercase mb-2 block">Stage 02</span>
                            <h3 class="text-lg font-black text-slate-400">2학년: 기초</h3>
                            <p class="text-[11px] text-slate-400 mt-1">데이터 수집 및 코딩</p>
                        </button>
                        <button onclick="updateRoadmap(3, this)" class="year-card bg-white p-6 rounded-[2rem] border border-slate-100 hover:border-blue-300 shadow-sm transition-all">
                            <span class="text-[10px] font-black text-slate-400 uppercase mb-2 block">Stage 03</span>
                            <h3 class="text-lg font-black text-slate-400">3학년: 심화</h3>
                            <p class="text-[11px] text-slate-400 mt-1">AI 모델링 및 분석</p>
                        </button>
                        <button onclick="updateRoadmap(4, this)" class="year-card bg-white p-6 rounded-[2rem] border border-slate-100 hover:border-blue-300 shadow-sm transition-all">
                            <span class="text-[10px] font-black text-slate-400 uppercase mb-2 block">Stage 04</span>
                            <h3 class="text-lg font-black text-slate-400">4학년: 창업</h3>
                            <p class="text-[11px] text-slate-400 mt-1">현장 적용 및 상용화</p>
                        </button>
                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                        <div class="bg-white p-10 rounded-[2.5rem] border border-slate-100 shadow-sm">
                            <h4 class="text-sm font-black text-slate-900 mb-8 flex items-center gap-2">
                                <i class="fa-solid fa-list-check text-blue-600"></i> 중점 이수 과목 및 활동
                            </h4>
                            <ul id="roadmap-list" class="space-y-6 border-l-2 border-slate-100 ml-3 pl-8 relative">
                                <!-- Dynamic List -->
                            </ul>
                        </div>
                        <div class="bg-white p-10 rounded-[2.5rem] border border-slate-100 shadow-sm">
                            <h4 class="text-sm font-black text-slate-900 mb-8 flex items-center gap-2">
                                <i class="fa-solid fa-chart-line text-blue-600"></i> 성장 예상 AX 지표
                            </h4>
                            <div class="h-80"><canvas id="radarChart"></canvas></div>
                        </div>
                    </div>
                </div>

                <!-- Section: Startup -->
                <div id="section-startup" class="section-content hidden space-y-8 animate-in fade-in duration-500">
                    <div class="bg-slate-900 rounded-[3rem] p-12 text-white relative overflow-hidden shadow-2xl">
                        <div class="relative z-10">
                            <span class="px-4 py-1.5 bg-blue-600 rounded-full text-[10px] font-black uppercase tracking-widest mb-6 inline-block">Future Startup Idea</span>
                            <h3 class="text-4xl font-black mb-6 italic">Livestock AX-Navigator</h3>
                            <p class="text-slate-400 max-w-2xl leading-relaxed text-lg font-medium italic">
                                "축산 전공생의 실습 데이터가 비즈니스가 되는 세상, 전공 맞춤형 커리어 매니지먼트 플랫폼"
                            </p>
                            <div class="mt-12 flex gap-4">
                                <div class="bg-white/10 px-6 py-4 rounded-2xl border border-white/10">
                                    <p class="text-[10px] font-black text-blue-400 uppercase">Target</p>
                                    <p class="text-sm font-bold mt-1">전국 축산 관련 대학생</p>
                                </div>
                                <div class="bg-white/10 px-6 py-4 rounded-2xl border border-white/10">
                                    <p class="text-[10px] font-black text-blue-400 uppercase">Value</p>
                                    <p class="text-sm font-bold mt-1">데이터 기반 진로 설계</p>
                                </div>
                            </div>
                        </div>
                        <i class="fa-solid fa-rocket absolute -bottom-20 -right-20 text-[300px] text-white/5 rotate-12"></i>
                    </div>

                    <div class="grid grid-cols-3 gap-6">
                        <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm hover:shadow-xl transition-all">
                            <div class="w-12 h-12 bg-blue-100 rounded-2xl flex items-center justify-center text-blue-600 text-xl mb-6">
                                <i class="fa-solid fa-database"></i>
                            </div>
                            <h4 class="text-lg font-black text-slate-800 mb-3">데이터 허브</h4>
                            <p class="text-xs text-slate-500 leading-relaxed font-medium">전공생들의 실습 데이터를 수집/정제하여 스마트 축산 연구소에 판매하는 데이터 마켓플레이스 모델</p>
                        </div>
                        <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm hover:shadow-xl transition-all">
                            <div class="w-12 h-12 bg-emerald-100 rounded-2xl flex items-center justify-center text-emerald-600 text-xl mb-6">
                                <i class="fa-solid fa-user-gear"></i>
                            </div>
                            <h4 class="text-lg font-black text-slate-800 mb-3">AI 커리어 매칭</h4>
                            <p class="text-xs text-slate-500 leading-relaxed font-medium">개인의 학업 성취도와 실습 숙련도 데이터를 분석하여 최적의 스마트팜 취업 및 창업 경로 제시</p>
                        </div>
                        <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm hover:shadow-xl transition-all">
                            <div class="w-12 h-12 bg-amber-100 rounded-2xl flex items-center justify-center text-amber-600 text-xl mb-6">
                                <i class="fa-solid fa-network-wired"></i>
                            </div>
                            <h4 class="text-lg font-black text-slate-800 mb-3">전용 소셜 네트워크</h4>
                            <p class="text-xs text-slate-500 leading-relaxed font-medium">축산 기술 공유 및 전문가 멘토링이 이루어지는 전공자 전용 커뮤니티 플랫폼 기반 비즈니스</p>
                        </div>
                    </div>
                </div>

                <!-- Section: Analysis -->
                <div id="section-analysis" class="section-content hidden space-y-8 animate-in fade-in duration-500">
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                        <div class="lg:col-span-2 bg-white p-10 rounded-[3rem] border border-slate-100 shadow-sm">
                            <div class="flex items-center justify-between mb-8">
                                <h4 class="text-sm font-black text-slate-900 flex items-center gap-2 uppercase tracking-tight">
                                    <span class="w-2 h-2 bg-blue-600 rounded-full animate-pulse"></span> 실습 개체 바이오 리듬 (Live)
                                </h4>
                                <div class="flex items-center gap-4 text-[10px] font-black">
                                    <span class="flex items-center gap-1"><i class="fa-solid fa-circle text-blue-600"></i> 정상 범위</span>
                                    <span class="flex items-center gap-1"><i class="fa-solid fa-circle text-rose-500"></i> 임계치</span>
                                </div>
                            </div>
                            <div class="h-[400px]"><canvas id="liveChart"></canvas></div>
                        </div>

                        <div class="space-y-6">
                            <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm">
                                <h4 class="text-xs font-black text-slate-900 mb-6 flex items-center gap-2">
                                    <i class="fa-solid fa-keyboard text-blue-600"></i> 실습 데이터 입력
                                </h4>
                                <div class="space-y-4">
                                    <div>
                                        <label class="text-[10px] font-black text-slate-400 mb-1.5 block uppercase">측정 체온 (°C)</label>
                                        <input type="number" id="input-temp" value="38.5" step="0.1" class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-5 py-3.5 text-sm font-black text-blue-600 focus:outline-none focus:ring-2 ring-blue-500/20">
                                    </div>
                                    <button onclick="runAnalysis()" class="w-full py-4 gnu-bg text-white rounded-2xl text-xs font-black shadow-lg shadow-blue-200 active:scale-95 transition-all">AI 분석 실행</button>
                                </div>
                            </div>

                            <div id="diagnosis-card" class="bg-slate-900 p-8 rounded-[2.5rem] text-center text-white transition-all duration-500 shadow-2xl">
                                <i id="diag-icon" class="fa-solid fa-circle-check text-5xl text-emerald-400 mb-6 block"></i>
                                <h3 id="diag-title" class="text-2xl font-black text-emerald-400">정상</h3>
                                <p class="text-[11px] text-slate-400 mt-2 italic font-bold">실시간 개체 이상 징후 확인</p>
                                <div class="mt-8 pt-8 border-t border-white/10 text-left">
                                    <p id="diag-text" class="text-[11px] text-white/70 leading-relaxed font-medium">현재 개체의 대사 리듬이 안정적입니다. 정기적인 사양 관리 수칙을 준수하세요.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </main>
    </div>

    <script>
        const roadmapData = {
            1: {
                skills: [20, 15, 30, 25, 15],
                items: [
                    { title: "전공기초: 축산학원론", desc: "현대 축산업의 가치와 미래 AX 전환의 필요성 이해" },
                    { title: "AX입문: 파이썬 데이터 과학기초", desc: "축산 데이터를 다루기 위한 기초 프로그래밍 지식 습득" },
                    { title: "활동: 스마트 축산 동아리 'GNU-AGRI'", desc: "학과 내 ICT 연구 소모임 활동을 통한 실무 체험" },
                    { title: "목표: 데이터 해석 능력 함양", desc: "엑셀 및 기초 통계를 활용한 사양 데이터 전처리 연습" }
                ]
            },
            2: {
                skills: [50, 40, 55, 45, 40],
                items: [
                    { title: "전공: 가축번식학 & 생리학", desc: "정밀 축산을 위한 개체별 생체 주기 이해" },
                    { title: "AX기초: 스마트 축산 ICT 기기 제어", desc: "센서 인터페이스 및 아두이노 기반 환경 제어 학습" },
                    { title: "실습: 학내 스마트 실습장 실무", desc: "실제 가축의 생체 데이터를 수집하고 클라우드에 적재" },
                    { title: "자격증: 빅데이터 분석기사 필기", desc: "국가 공인 데이터 전문가로서의 이론적 토대 마련" }
                ]
            },
            3: {
                skills: [80, 70, 85, 75, 75],
                items: [
                    { title: "전공: 가축영양학 & 사료공학", desc: "AI 기반 정밀 사료 배합 및 급이 알고리즘 설계" },
                    { title: "AX심화: 머신러닝 기반 질병 예찰", desc: "가축의 행동 및 체온 데이터를 통한 이상 탐지 모델 구현" },
                    { title: "캡스톤: AX 솔루션 프로토타입", desc: "실제 농장 문제를 해결하는 AI 기반 통합 관제 서비스 기획" },
                    { title: "인턴십: 스마트 축산 선도 기업", desc: "방학 기간을 활용한 현장 밀착형 실무 경험 축적" }
                ]
            },
            4: {
                skills: [98, 95, 99, 90, 95],
                items: [
                    { title: "전공: 축산 경영전략 & 경제학", desc: "데이터 기반 농장 생산성 분석 및 수익성 극대화 전략" },
                    { title: "AX전문: 통합 AX 플랫폼 구축", desc: "모바일/웹 기반의 농장 관리 토탈 솔루션 졸업 작품 완성" },
                    { title: "창업: 비즈니스 모델 구체화", desc: "혁신 창업 지원 사업 연계 및 스타트업 피칭 준비" },
                    { title: "목표: 스마트 축산 컨설턴트 도약", desc: "현장과 이론을 겸비한 지능형 축산 전문가로 사회 진출" }
                ]
            }
        };

        let radarChart, liveChart;

        function initCharts() {
            Chart.defaults.font.family = 'Pretendard';
            Chart.defaults.color = '#64748b';

            // Radar Chart
            const ctxRadar = document.getElementById('radarChart').getContext('2d');
            radarChart = new Chart(ctxRadar, {
                type: 'radar',
                data: {
                    labels: ['전공지식', 'AI코딩', '데이터해석', '경영전략', '실습숙련'],
                    datasets: [{
                        label: '나의 성장 지수',
                        data: roadmapData[1].skills,
                        backgroundColor: 'rgba(0, 78, 162, 0.1)',
                        borderColor: '#004ea2',
                        borderWidth: 3,
                        pointBackgroundColor: '#004ea2',
                        pointRadius: 4
                    }]
                },
                options: {
                    scales: { r: { beginAtZero: true, max: 100, ticks: { display: false } } },
                    plugins: { legend: { display: false } }
                }
            });

            // Live Stream Chart
            const ctxLive = document.getElementById('liveChart').getContext('2d');
            liveChart = new Chart(ctxLive, {
                type: 'line',
                data: {
                    labels: Array.from({length: 20}, (_, i) => i + 's'),
                    datasets: [{
                        data: Array.from({length: 20}, () => 38.5),
                        borderColor: '#004ea2',
                        borderWidth: 3,
                        tension: 0.4,
                        fill: true,
                        backgroundColor: 'rgba(0, 78, 162, 0.05)',
                        pointRadius: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    animation: false,
                    scales: { y: { min: 37, max: 41 }, x: { display: false } },
                    plugins: { legend: { display: false } }
                }
            });

            setInterval(() => {
                liveChart.data.datasets[0].data.shift();
                const base = isHigh ? 40.2 : 38.5;
                const noise = Math.random() * 0.4 - 0.2;
                liveChart.data.datasets[0].data.push(base + noise);
                liveChart.update();
            }, 1000);
        }

        function showSection(id, btn) {
            document.querySelectorAll('.section-content').forEach(s => s.classList.add('hidden'));
            document.getElementById('section-' + id).classList.remove('hidden');
            document.querySelectorAll('.sidebar-item').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            document.getElementById('section-title').innerText = btn.innerText;
        }

        function updateRoadmap(year, btn) {
            document.querySelectorAll('.year-card').forEach(c => {
                c.classList.remove('border-blue-600', 'shadow-xl', 'scale-105');
                c.classList.add('border-slate-100', 'shadow-sm');
                c.querySelector('h3').classList.add('text-slate-400');
                c.querySelector('span').classList.replace('text-blue-600', 'text-slate-400');
            });
            btn.classList.add('border-blue-600', 'shadow-xl', 'scale-105');
            btn.classList.remove('border-slate-100', 'shadow-sm');
            btn.querySelector('h3').classList.remove('text-slate-400');
            btn.querySelector('span').classList.replace('text-slate-400', 'text-blue-600');

            // List Update
            const list = document.getElementById('roadmap-list');
            list.innerHTML = '';
            roadmapData[year].items.forEach(item => {
                list.innerHTML += `
                    <li class="relative">
                        <div class="absolute -left-[41px] top-1 w-5 h-5 bg-white border-4 border-blue-600 rounded-full z-10"></div>
                        <h5 class="font-black text-slate-800 text-sm italic">${item.title}</h5>
                        <p class="text-[11px] text-slate-500 font-medium mt-1">${item.desc}</p>
                    </li>
                `;
            });

            // Radar Update
            radarChart.data.datasets[0].data = roadmapData[year].skills;
            radarChart.update();
        }

        let isHigh = false;
        function runAnalysis() {
            const temp = parseFloat(document.getElementById('input-temp').value);
            const card = document.getElementById('diagnosis-card');
            const icon = document.getElementById('diag-icon');
            const title = document.getElementById('diag-title');
            const text = document.getElementById('diag-text');

            if(temp >= 39.8) {
                isHigh = true;
                card.className = "bg-rose-900 p-8 rounded-[2.5rem] text-center text-white transition-all duration-500 shadow-2xl scale-105 border-2 border-rose-500";
                icon.className = "fa-solid fa-triangle-exclamation text-5xl text-rose-400 mb-6 block";
                title.innerText = "주의 (Warning)";
                title.className = "text-2xl font-black text-rose-400";
                text.innerText = "개체 온도가 임계치를 초과했습니다. 축사 내 환기 상태를 점검하고, 개체의 사료 섭취량 변화를 실습 일지에 상세히 기록하세요.";
            } else {
                isHigh = false;
                card.className = "bg-slate-900 p-8 rounded-[2.5rem] text-center text-white transition-all duration-500 shadow-2xl";
                icon.className = "fa-solid fa-circle-check text-5xl text-emerald-400 mb-6 block";
                title.innerText = "정상 (Normal)";
                title.className = "text-2xl font-black text-emerald-400";
                text.innerText = "현재 개체의 대사 리듬이 안정적입니다. 정기적인 사양 관리 수칙을 준수하세요.";
            }
        }

        window.onload = () => {
            initCharts();
            updateRoadmap(1, document.querySelector('.year-card'));
        };
    </script>
</body>
</html>
