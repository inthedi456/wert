        <!-- 메뉴 버튼 -->
        <div class="flex flex-row md:flex-col w-full p-2 md:p-4 gap-1 md:gap-2">
            <button onclick="changeTab('roadmap')" id="btn-roadmap" class="nav-btn active flex-1 md:w-full flex md:flex-row flex-col items-center gap-1 md:gap-3 px-2 md:px-4 py-3 md:py-4 rounded-xl text-xs md:text-sm font-bold text-slate-500 hover:bg-slate-50 transition-all border border-transparent">
