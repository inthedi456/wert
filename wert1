<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GNU 축산 AX 커리어 로드맵</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Pretendard:wght@400;600;800&display=swap');
        body { font-family: 'Pretendard', sans-serif; background-color: #f3f4f6; overflow: hidden; }
        .gnu-blue { color: #004ea2; }
        .gnu-bg { background-color: #004ea2; }
        .card-active { border-left: 5px solid #004ea2; background-color: #f0f7ff; }
        .step-line::before { content: ''; position: absolute; left: 20px; top: 0; bottom: 0; width: 2px; background: #e5e7eb; z-index: 0; }
        .custom-scroll::-webkit-scrollbar { width: 5px; }
        .custom-scroll::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    </style>
</head>
<body class="text-slate-800">

    <div class="flex h-screen overflow-hidden">
        <!-- 사이드바: 커리어 메뉴 -->
        <aside class="w-72 bg-white border-r border-slate-200 flex flex-col shrink-0">
            <div class="p-6 border-b border-slate-50">
                <div class="flex items-center gap-3 mb-2">
                    <div class="w-10 h-10 gnu-bg rounded-xl flex items-center justify-center text-white shadow-lg">
                        <i class="fa-solid fa-route"></i>
                    </div>
                    <div>
                        <h1 class="text-lg font-extrabold tracking-tighter">GNU AX Path</h1>
                        <p class="text-[10px] text-blue-600 font-bold uppercase italic">Career & Action Plan</p>
                    </div>
                </div>
                <p class="text-[11px] text-slate-400 font-medium leading-tight">축산과학부 신입생을 위한<br>지능형 커리어 설계 솔루션</p>
            </div>

            <nav class="flex-1 p-4 space-y-2 overflow-y-auto custom-scroll">
                <div class="text-[10px] font-bold text-slate-400 px-3 mb-2 uppercase">Main Plan</div>
                <button onclick="switchTab('tab-roadmap', this)" class="tab-btn card-active w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-bold text-left transition-all">
                    <i class="fa-solid fa-map-location-dot"></i> 4개년 교육 로드맵
                </button>
                <button onclick="switchTab('tab-startup', this)" class="tab-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-bold text-left text-slate-500 hover:bg-slate-50 transition-all">
                    <i class="fa-solid fa-lightbulb"></i> 창업 아이템 구상
                </button>
                
                <div class="pt-6 text-[10px] font-bold text-slate-400 px-3 mb-2 uppercase">Analysis</div>
                <button onclick="switchTab('tab-monitor', this)" class="tab-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-bold text-left text-slate-500 hover:bg-slate-50 transition-all">
                    <i class="fa-solid fa-microchip"></i> 실시간 개체 진단(실습)
                </button>
            </nav>

            <div class="p-6 bg-slate-50 border-t border-slate-100 text-center">
                <p class="text-[10px] text-slate-400 font-bold mb-2 uppercase">현재 진행도</p>
                <div class="w-full bg-slate-200 h-2 rounded-full overflow-hidden mb-2">
                    <div class="bg-blue-600 h-full w-[15%]"></div>
                </div>
                <p class="text-[11px] font-black gnu-blue">1학년 1학기 항해 중</p>
            </div>
        </aside>

        <!-- 메인 화면 -->
        <main class="flex-1 flex flex-col bg-[#f9fafb]">
            <header class="h-16 bg-white border-b border-slate-200 px-8 flex items-center justify-between">
                <div>
                    <h2 id="view-title" class="text-lg font-black text-slate-900 tracking-tight italic">4개년 교육 로드맵</h2>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-xs font-bold text-slate-500">경상국립대 축산과학부 신입생 [질문자님]</span>
                    <div class="w-8 h-8 rounded-full gnu-bg flex items-center justify-center text-white text-xs font-bold shadow-md">GNU</div>
                </div>
            </header>

            <div class="flex-1 overflow-y-auto p-8 custom-scroll">
                
                <!-- 1. 교육 로드맵 탭 -->
                <div id="tab-roadmap" class="tab-content space-y-6">
                    <div class="grid grid-cols-4 gap-4 mb-8">
                        <button onclick="showYear(1, this)" class="year-btn p-4 rounded-2xl bg-white border-2 border-blue-600 shadow-md transform scale-105 transition-all">
                            <p class="text-[10px] font-black text-blue-600 mb-1">STEP 01</p>
                            <h3 class="font-black text-slate-800">1학년: 탐색</h3>
                            <p class="text-[10px] text-slate-400 mt-1">AX 기초 및 전공입문</p>
                        </button>
                        <button onclick="showYear(2, this)" class="year-btn p-4 rounded-2xl bg-white border border-slate-200 hover:border-blue-300 transition-all">
                            <p class="text-[10px] font-black text-slate-400 mb-1">STEP 02</p>
                            <h3 class="font-black text-slate-800">2학년: 기초</h3>
                            <p class="text-[10px] text-slate-400 mt-1">데이터 수집 및 코딩</p>
                        </button>
                        <button onclick="showYear(3, this)" class="year-btn p-4 rounded-2xl bg-white border border-slate-200 hover:border-blue-300 transition-all">
                            <p class="text-[10px] font-black text-slate-400 mb-1">STEP 03</p>
                            <h3 class="font-black text-slate-800">3학년: 심화</h3>
                            <p class="text-[10px] text-slate-400 mt-1">AI 모델링 및 분석</p>
                        </button>
                        <button onclick="showYear(4, this)" class="year-btn p-4 rounded-2xl bg-white border border-slate-200 hover:border-blue-300 transition-all">
                            <p class="text-[10px] font-black text-slate-400 mb-1">STEP 04</p>
                            <h3 class="font-black text-slate-800">4학년: 도약</h3>
                            <p class="text-[10px] text-slate-400 mt-1">창업 및 현장 적용</p>
                        </button>
                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                        <!-- 왼쪽: 학년별 상세 교육과정 -->
                        <div class="bg-white p-8 rounded-3xl border border-slate-100 shadow-sm relative overflow-hidden">
                            <div class="absolute top-0 right-0 p-4 opacity-10 text-6xl gnu-blue font-black" id="year-watermark">1st</div>
                            <h4 class="text-sm font-black text-slate-900 mb-6 flex items-center gap-2">
                                <i class="fa-solid fa-book-open text-blue-600"></i> 학년별 중점 이수 과목
                            </h4>
                            <div class="space-y-4 relative step-line" id="roadmap-list">
                                <!-- JS로 내용 삽입 -->
                            </div>
                        </div>

                        <!-- 오른쪽: 역량 지표 차트 -->
                        <div class="bg-white p-8 rounded-3xl border border-slate-100 shadow-sm">
                            <h4 class="text-sm font-black text-slate-900 mb-6 flex items-center gap-2">
                                <i class="fa-solid fa-chart-radar text-blue-600"></i> 졸업 시 예상 AX 역량
                            </h4>
                            <div class="h-80"><canvas id="skillChart"></canvas></div>
                        </div>
                    </div>
                </div>

                <!-- 2. 창업 아이템 탭 -->
                <div id="tab-startup" class="tab-content hidden space-y-6">
                    <div class="bg-indigo-900 rounded-3xl p-10 text-white relative overflow-hidden shadow-2xl">
                        <div class="relative z-10">
                            <span class="px-3 py-1 bg-indigo-500 rounded-full text-[10px] font-black uppercase tracking-widest mb-4 inline-block">Startup Idea</span>
                            <h2 class="text-3xl font-black mb-4 italic">"GNU Livestock AX-Navigator"</h2>
                            <p class="text-slate-300 max-w-2xl leading-relaxed font-medium">
                                축산 전공 학생들의 실습 데이터와 학업 성취도를 결합하여, 미래의 축산 경영인이나 
                                스마트 축산 전문가로서의 커리어를 자동으로 설계해주는 '전공 맞춤형 커리어 매니지먼트' 창업 아이템입니다.
                            </p>
                        </div>
                        <i class="fa-solid fa-rocket absolute -bottom-10 -right-10 text-[200px] text-white opacity-5"></i>
                    </div>
                    
                    <div class="grid grid-cols-3 gap-6">
                        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
                            <i class="fa-solid fa-database text-blue-600 text-2xl mb-4"></i>
                            <h4 class="font-black text-slate-800 mb-2">데이터 비즈니스</h4>
                            <p class="text-xs text-slate-500 leading-relaxed">학생 실습 데이터를 익명화하여 연구소에 제공하는 데이터 허브 구축</p>
                        </div>
                        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
                            <i class="fa-solid fa-robot text-emerald-600 text-2xl mb-4"></i>
                            <h4 class="font-black text-slate-800 mb-2">맞춤형 컨설팅</h4>
                            <p class="text-xs text-slate-500 leading-relaxed">성적과 역량에 따라 맞춤형 스마트팜 취업/창업 경로 매칭 알고리즘</p>
                        </div>
                        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
                            <i class="fa-solid fa-network-wired text-rose-600 text-2xl mb-4"></i>
                            <h4 class="font-black text-slate-800 mb-2">전용 플랫폼</h4>
                            <p class="text-xs text-slate-500 leading-relaxed">전국 축산 전공자들을 연결하는 AX 기술 공유 및 전문가 네트워킹 플랫폼</p>
                        </div>
                    </div>
                </div>

                <!-- 3. 실습 진단 탭 (기능 유지) -->
                <div id="tab-monitor" class="tab-content hidden space-y-6">
                    <div class="bg-white p-8 rounded-3xl border border-slate-100 shadow-sm flex flex-col lg:flex-row items-center gap-8">
                        <div class="flex-1 w-full h-80"><canvas id="streamChart"></canvas></div>
                        <div id="status-card" class="w-full lg:w-80 bg-slate-900 p-8 rounded-3xl text-center text-white transition-all duration-500">
                            <i id="status-icon" class="fa-solid fa-check-circle text-5xl text-emerald-400 mb-4 block"></i>
                            <h3 id="status-title" class="text-2xl font-black text-emerald-400">정상</h3>
                            <p class="text-[11px] text-slate-400 mt-2 italic font-bold">실시간 개체 이상 징후 확인</p>
                            <div class="mt-6 pt-6 border-t border-white/10">
                                <input type="number" id="test-temp" value="38.5" step="0.1" class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-2 text-sm font-bold text-white mb-3 text-center">
                                <button onclick="checkHealth()" class="w-full py-3 gnu-bg rounded-xl text-xs font-black active:scale-95 transition-all">실습 데이터 분석</button>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </main>
    </div>

    <script>
        const yearContent = {
            1: {
                watermark: "1st",
                roadmap: [
                    { title: "전공기초: 축산학원론", desc: "축산업의 역사와 미래 산업 전망 이해" },
                    { title: "AX입문: 파이썬 코딩기초", desc: "데이터 분석을 위한 기초 프로그래밍 학습" },
                    { title: "교양: AI와 미래사회", desc: "인공지능 기술의 흐름과 윤리 이해" },
                    { title: "활동: 학과 동아리 가입", desc: "스마트 축산 연구 동아리에서 선배들과 교류" }
                ],
                skills: [20, 15, 30, 10, 20]
            },
            2: {
                watermark: "2nd",
                roadmap: [
                    { title: "전공: 가축번식학 & 생리학", desc: "가축의 생체 메커니즘 심화 이해" },
                    { title: "AX심화: 축산 데이터 분석", desc: "Pandas/Numpy를 활용한 사양 데이터 처리" },
                    { title: "실습: 스마트 ICT 기기 운용", desc: "센서 데이터 수집 및 네트워크 연동 실무" },
                    { title: "자격증: 빅데이터분석기사 준비", desc: "국가 공인 자격증 취득을 위한 이론 공부" }
                ],
                skills: [50, 45, 60, 40, 45]
            },
            3: {
                watermark: "3rd",
                roadmap: [
                    { title: "전공: 가축영양학 & 사료학", desc: "정밀 사양을 위한 영양소 설계 학습" },
                    { title: "AX전문: 머신러닝 모델링", desc: "질병 예찰 및 생산성 예측 AI 모델 개발" },
                    { title: "캡스톤: 스마트팜 솔루션 설계", desc: "팀 프로젝트를 통한 실질적 문제 해결" },
                    { title: "인턴십: 스마트 축산 기업 현장", desc: "실제 산업 현장의 AX 적용 사례 체험" }
                ],
                skills: [80, 75, 85, 75, 70]
            },
            4: {
                watermark: "4th",
                roadmap: [
                    { title: "전문: 축산 경영전략", desc: "데이터 기반 농장 경영 및 경제성 분석" },
                    { title: "창업: AX 스타트업 실무", desc: "비즈니스 모델 수립 및 정부 지원 사업 준비" },
                    { title: "졸업작품: AI 기반 통합 관제 시스템", desc: "4년간의 역량을 집약한 최종 결과물 완성" },
                    { title: "커리어: 취업 및 창업 도약", desc: "스마트 축산 전문가로서 사회 진출" }
                ],
                skills: [98, 95, 99, 90, 95]
            }
        };

        let skillChart, streamChart;

        function init() {
            showYear(1, document.querySelector('.year-btn'));
            initStreamChart();
        }

        function switchTab(tabId, btn) {
            document.querySelectorAll('.tab-content').forEach(t => t.classList.add('hidden'));
            document.getElementById(tabId).classList.remove('hidden');
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('card-active', 'text-slate-900'));
            btn.classList.add('card-active');
            document.getElementById('view-title').innerText = btn.innerText;
        }

        function showYear(year, btn) {
            // 버튼 스타일 업데이트
            document.querySelectorAll('.year-btn').forEach(b => {
                b.classList.remove('border-blue-600', 'shadow-md', 'scale-105');
                b.classList.add('border-slate-200');
                b.querySelector('p').classList.replace('text-blue-600', 'text-slate-400');
            });
            btn.classList.add('border-blue-600', 'shadow-md', 'scale-105');
            btn.querySelector('p').classList.replace('text-slate-400', 'text-blue-600');

            const content = yearContent[year];
            document.getElementById('year-watermark').innerText = content.watermark;
            
            // 리스트 업데이트
            const list = document.getElementById('roadmap-list');
            list.innerHTML = '';
            content.roadmap.forEach(item => {
                list.innerHTML += `
                    <div class="relative pl-10 pb-2 z-10">
                        <div class="absolute left-0 w-10 h-10 gnu-bg rounded-full border-4 border-white flex items-center justify-center text-white text-[10px]">
                            <i class="fa-solid fa-check"></i>
                        </div>
                        <h5 class="font-black text-slate-800 text-sm">${item.title}</h5>
                        <p class="text-[11px] text-slate-400 font-medium">${item.desc}</p>
                    </div>
                `;
            });

            // 차트 업데이트
            updateSkillChart(content.skills);
        }

        function updateSkillChart(data) {
            if (skillChart) skillChart.destroy();
            const ctx = document.getElementById('skillChart').getContext('2d');
            skillChart = new Chart(ctx, {
                type: 'radar',
                data: {
                    labels: ['전공지식', 'AI코딩', '데이터해석', '경영전략', '실습숙련'],
                    datasets: [{
                        label: '학년별 역량지수',
                        data: data,
                        backgroundColor: 'rgba(0, 78, 162, 0.1)',
                        borderColor: '#004ea2',
                        borderWidth: 3,
                        pointBackgroundColor: '#004ea2'
                    }]
                },
                options: {
                    scales: { r: { beginAtZero: true, max: 100, ticks: { display: false } } },
                    plugins: { legend: { display: false } }
                }
            });
        }

        function initStreamChart() {
            const ctx = document.getElementById('streamChart').getContext('2d');
            streamChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: Array.from({length: 20}, (_, i) => i + 's'),
                    datasets: [{
                        data: Array.from({length: 20}, () => 38.5),
                        borderColor: '#004ea2',
                        borderWidth: 3,
                        tension: 0.4,
                        fill: true,
                        backgroundColor: 'rgba(0, 78, 162, 0.05)',
                        pointRadius: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: { y: { min: 37, max: 41 }, x: { display: false } },
                    plugins: { legend: { display: false } },
                    animation: false
                }
            });

            setInterval(() => {
                streamChart.data.datasets[0].data.shift();
                const temp = isHigh ? 40 + (Math.random()*0.5) : 38.5 + (Math.random()*0.2-0.1);
                streamChart.data.datasets[0].data.push(temp);
                streamChart.update();
            }, 1000);
        }

        let isHigh = false;
        function checkHealth() {
            const temp = document.getElementById('test-temp').value;
            const card = document.getElementById('status-card');
            const icon = document.getElementById('status-icon');
            const title = document.getElementById('status-title');

            if(temp >= 39.5) {
                isHigh = true;
                card.className = "w-full lg:w-80 bg-rose-900 p-8 rounded-3xl text-center text-white transition-all duration-500 scale-105 shadow-2xl";
                icon.className = "fa-solid fa-triangle-exclamation text-5xl text-rose-400 mb-4 block";
                title.innerText = "주의";
                title.classList.replace('text-emerald-400', 'text-rose-400');
            } else {
                isHigh = false;
                card.className = "w-full lg:w-80 bg-slate-900 p-8 rounded-3xl text-center text-white transition-all duration-500 shadow-xl";
                icon.className = "fa-solid fa-check-circle text-5xl text-emerald-400 mb-4 block";
                title.innerText = "정상";
                title.classList.replace('text-rose-400', 'text-emerald-400');
            }
        }

        window.onload = init;
    </script>
</body>
</html>
