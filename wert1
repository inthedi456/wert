<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GNU 축산과학부 | AX 지능화 실무 대시보드</title>
    
    <!-- 디자인 엔진: Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- 차트 엔진: Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- 아이콘 팩: Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Pretendard:wght@400;600;700;900&display=swap');
        
        :root {
            --gnu-blue: #004ea2;
            --gnu-dark: #002d62;
        }

        body { 
            font-family: 'Pretendard', sans-serif; 
            background-color: #f8fafc;
            color: #1e293b;
        }

        .gnu-gradient {
            background: linear-gradient(135deg, var(--gnu-blue) 0%, var(--gnu-dark) 100%);
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            border-radius: 2rem;
            box-shadow: 0 10px 25px -5px rgba(0, 78, 162, 0.05);
        }

        .nav-active {
            background-color: var(--gnu-blue);
            color: white !important;
            box-shadow: 0 4px 12px rgba(0, 78, 162, 0.3);
        }

        /* 애니메이션 효과 */
        .fade-in { animation: fadeIn 0.5s ease-out; }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        input[type="number"]::-webkit-inner-spin-button { display: none; }
    </style>
</head>
<body class="min-h-screen">

    <!-- 사이드바 내비게이션 -->
    <div class="flex h-screen overflow-hidden">
        <aside class="w-72 gnu-gradient p-8 flex flex-col shrink-0">
            <div class="mb-12">
                <div class="flex items-center gap-3 mb-2">
                    <div class="bg-white p-2 rounded-xl">
                        <i class="fa-solid fa-cow text-[#004ea2] text-xl"></i>
                    </div>
                    <h1 class="text-white font-black text-xl tracking-tighter">GNU AX HUB</h1>
                </div>
                <p class="text-blue-200 text-[10px] font-bold uppercase tracking-widest leading-none">Animal Science & AI</p>
            </div>

            <nav class="space-y-2 flex-1">
                <button onclick="switchTab('dashboard', this)" class="tab-btn nav-active w-full flex items-center gap-3 px-5 py-4 rounded-2xl text-sm font-bold transition-all">
                    <i class="fa-solid fa-chart-pie w-5"></i> 관제 대시보드
                </button>
                <button onclick="switchTab('simulator', this)" class="tab-btn text-blue-100 hover:bg-white/10 w-full flex items-center gap-3 px-5 py-4 rounded-2xl text-sm font-bold transition-all">
                    <i class="fa-solid fa-microchip w-5"></i> AI 진단 시뮬레이터
                </button>
                <button onclick="switchTab('infra', this)" class="tab-btn text-blue-100 hover:bg-white/10 w-full flex items-center gap-3 px-5 py-4 rounded-2xl text-sm font-bold transition-all">
                    <i class="fa-solid fa-network-wired w-5"></i> 실습 인프라 정보
                </button>
            </nav>

            <div class="mt-auto bg-white/10 p-5 rounded-2xl border border-white/10">
                <p class="text-[10px] text-blue-200 font-bold mb-2 uppercase">My Status</p>
                <p class="text-white text-xs font-bold leading-relaxed">경상국립대 축산과학부<br>26학번 신입생</p>
            </div>
        </aside>

        <!-- 메인 콘텐츠 -->
        <main class="flex-1 overflow-y-auto p-10">
            
            <!-- 대시보드 탭 -->
            <div id="dashboard" class="tab-content fade-in space-y-8">
                <header class="flex justify-between items-end">
                    <div>
                        <h2 class="text-3xl font-black text-slate-800 italic">Strategic Dashboard</h2>
                        <p class="text-slate-400 text-sm font-medium mt-1">국가 AI 전략에 따른 축산 지능화 실천 계획</p>
                    </div>
                    <div class="text-right">
                        <p class="text-[10px] font-black text-blue-600 uppercase">Current Session</p>
                        <p id="current-time" class="text-sm font-bold text-slate-500 font-mono">00:00:00</p>
                    </div>
                </header>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="glass-card p-8">
                        <p class="text-xs font-bold text-slate-400 uppercase mb-2">AX 기술 습득률</p>
                        <div class="flex items-baseline gap-2">
                            <span class="text-4xl font-black text-[#004ea2]">28</span>
                            <span class="text-lg font-bold text-slate-300">%</span>
                        </div>
                        <div class="w-full bg-slate-100 h-2 rounded-full mt-6">
                            <div class="gnu-gradient h-full w-[28%] rounded-full shadow-lg shadow-blue-200"></div>
                        </div>
                    </div>
                    <div class="glass-card p-8">
                        <p class="text-xs font-bold text-slate-400 uppercase mb-2">실시간 분석 모드</p>
                        <div class="flex items-center gap-3">
                            <div class="w-3 h-3 bg-emerald-500 rounded-full animate-pulse"></div>
                            <span class="text-2xl font-black text-slate-700 uppercase">Active</span>
                        </div>
                        <p class="text-[10px] text-emerald-600 font-bold mt-4 italic">Connected to GNU Cloud</p>
                    </div>
                    <div class="glass-card p-8">
                        <p class="text-xs font-bold text-slate-400 uppercase mb-2">미래 역량 등급</p>
                        <div class="flex items-baseline gap-2">
                            <span class="text-4xl font-black text-indigo-600">A</span>
                            <span class="text-lg font-bold text-slate-300">Class</span>
                        </div>
                        <p class="text-[10px] text-slate-400 font-bold mt-4 uppercase">Target: AI Specialist</p>
                    </div>
                </div>

                <div class="glass-card p-10">
                    <h3 class="text-lg font-black text-slate-800 mb-8 flex items-center gap-2">
                        <i class="fa-solid fa-arrow-trend-up text-blue-600"></i> 학기별 AI 역량 시뮬레이션
                    </h3>
                    <div class="h-80 w-full">
                        <canvas id="mainChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- 시뮬레이터 탭 -->
            <div id="simulator" class="tab-content hidden fade-in space-y-6">
                <h2 class="text-3xl font-black text-slate-800 italic mb-8">AI Diagnosis Simulator</h2>
                
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                    <div class="glass-card p-10">
                        <h4 class="font-bold text-slate-800 mb-6 flex items-center gap-2">
                            <i class="fa-solid fa-thermometer-half text-rose-500"></i> 실습 개체 데이터 입력
                        </h4>
                        <div class="space-y-6">
                            <div>
                                <label class="text-[10px] font-black text-slate-400 uppercase block mb-2">대상 개체 코드</label>
                                <input type="text" value="GNU-COW-001" readonly class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-5 py-4 text-sm font-bold text-slate-500 outline-none">
                            </div>
                            <div>
                                <label class="text-[10px] font-black text-slate-400 uppercase block mb-2">측정 체온 (°C)</label>
                                <input type="number" id="tempInput" value="38.5" step="0.1" class="w-full bg-blue-50/50 border border-blue-100 rounded-2xl px-5 py-4 text-lg font-black text-[#004ea2] focus:ring-4 ring-blue-500/10 outline-none transition-all">
                            </div>
                            <button onclick="runSimulation()" class="w-full py-5 gnu-gradient text-white rounded-2xl font-black text-sm shadow-xl shadow-blue-200 active:scale-95 transition-all">AI 분석 엔진 가동</button>
                        </div>
                    </div>

                    <div id="simResult" class="glass-card p-10 bg-slate-900 flex flex-col items-center justify-center text-center text-white border-none shadow-2xl transition-all duration-500">
                        <div id="resultIcon" class="w-20 h-20 bg-emerald-500/20 rounded-3xl flex items-center justify-center text-3xl text-emerald-400 mb-6">
                            <i class="fa-solid fa-shield-cat"></i>
                        </div>
                        <h3 id="resultTitle" class="text-2xl font-black text-emerald-400 mb-3">상태 양호</h3>
                        <p id="resultDesc" class="text-sm text-slate-400 leading-relaxed max-w-[280px]">현재 실습 대상의 생체 리듬이 정상 범위 내에 있습니다. 실시간 모니터링을 지속하십시오.</p>
                        
                        <div class="mt-10 pt-8 border-t border-white/10 w-full text-left">
                            <p class="text-[10px] font-bold text-blue-400 uppercase mb-1">AI Recommendation</p>
                            <p id="resultAction" class="text-xs text-slate-300 font-medium">● 정기적인 데이터 로깅 필요 (매 2시간)</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 인프라 탭 -->
            <div id="infra" class="tab-content hidden fade-in">
                <div class="glass-card p-12 text-center max-w-4xl mx-auto">
                    <div class="w-20 h-20 gnu-gradient rounded-3xl flex items-center justify-center text-3xl text-white mx-auto mb-8 shadow-xl">
                        <i class="fa-solid fa-server"></i>
                    </div>
                    <h2 class="text-3xl font-black text-slate-800 mb-4 tracking-tighter uppercase">Academic Infrastructure</h2>
                    <p class="text-slate-500 leading-relaxed mb-10 font-medium">
                        경상국립대학교 축산과학부는 'AI 고속도로' 정책에 발맞추어<br>
                        학생 개개인에게 클라우드 분석 환경을 제공하며, 스마트 팜과 실시간으로 연동됩니다.
                    </p>
                    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                        <div class="p-6 bg-slate-50 rounded-2xl border border-slate-100">
                            <i class="fa-solid fa-wifi text-blue-500 mb-3"></i>
                            <p class="text-[10px] font-bold text-slate-400 uppercase">Network</p>
                            <p class="text-sm font-black text-slate-800">10Gbps Dedicated</p>
                        </div>
                        <div class="p-6 bg-slate-50 rounded-2xl border border-slate-100">
                            <i class="fa-solid fa-microchip text-indigo-500 mb-3"></i>
                            <p class="text-[10px] font-bold text-slate-400 uppercase">GPU Power</p>
                            <p class="text-sm font-black text-slate-800">H100 Cluster</p>
                        </div>
                        <div class="p-6 bg-slate-50 rounded-2xl border border-slate-100 col-span-2 md:col-span-1">
                            <i class="fa-solid fa-lock text-emerald-500 mb-3"></i>
                            <p class="text-[10px] font-bold text-slate-400 uppercase">Security</p>
                            <p class="text-sm font-black text-slate-800">GNU-Auth v2</p>
                        </div>
                    </div>
                </div>
            </div>

        </main>
    </div>

    <script>
        // 현재 시간 업데이트
        function updateClock() {
            const now = new Date();
            document.getElementById('current-time').innerText = now.toLocaleTimeString('ko-KR', { hour12: false });
        }
        setInterval(updateClock, 1000);
        updateClock();

        // 탭 전환 기능
        function switchTab(tabId, btn) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
            document.getElementById(tabId).classList.remove('hidden');
            
            document.querySelectorAll('.tab-btn').forEach(el => {
                el.classList.remove('nav-active');
                el.classList.add('text-blue-100', 'hover:bg-white/10');
            });
            btn.classList.add('nav-active');
            btn.classList.remove('text-blue-100', 'hover:bg-white/10');
        }

        // 차트 설정
        let mainChart;
        function initChart() {
            const ctx = document.getElementById('mainChart').getContext('2d');
            mainChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['1학년', '2학년', '3학년', '4학년'],
                    datasets: [{
                        label: 'AX 실무 역량 지표',
                        data: [15, 42, 78, 98],
                        borderColor: '#004ea2',
                        borderWidth: 6,
                        backgroundColor: 'rgba(0, 78, 162, 0.1)',
                        fill: true,
                        tension: 0.4,
                        pointBackgroundColor: '#fff',
                        pointBorderColor: '#004ea2',
                        pointBorderWidth: 4,
                        pointRadius: 6,
                        pointHoverRadius: 10
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, max: 100, grid: { color: '#f1f5f9' } },
                        x: { grid: { display: false } }
                    }
                }
            });
        }

        // 시뮬레이션 엔진
        function runSimulation() {
            const temp = parseFloat(document.getElementById('tempInput').value);
            const card = document.getElementById('simResult');
            const icon = document.getElementById('resultIcon');
            const title = document.getElementById('resultTitle');
            const desc = document.getElementById('resultDesc');
            const action = document.getElementById('resultAction');

            // 분석 중 효과를 위한 딜레이
            title.innerText = "분석 중...";
            title.className = "text-2xl font-black text-blue-400 animate-pulse";
            
            setTimeout(() => {
                if(temp >= 39.5) {
                    card.className = "glass-card p-10 bg-rose-950 flex flex-col items-center justify-center text-center text-white border-none shadow-2xl transition-all duration-500 scale-105";
                    icon.className = "w-20 h-20 bg-rose-500/20 rounded-3xl flex items-center justify-center text-3xl text-rose-400 mb-6";
                    icon.innerHTML = '<i class="fa-solid fa-triangle-exclamation"></i>';
                    title.innerText = "이상 징후 감지";
                    title.className = "text-2xl font-black text-rose-400 mb-3";
                    desc.innerText = "개체의 체온이 임계치를 초과했습니다. 열성 질병 혹은 스트레스 징후가 의심됩니다.";
                    action.innerText = "● 격리 조치 검토 및 수의사(교수님) 보고 요망";
                } else {
                    card.className = "glass-card p-10 bg-slate-900 flex flex-col items-center justify-center text-center text-white border-none shadow-2xl transition-all duration-500";
                    icon.className = "w-20 h-20 bg-emerald-500/20 rounded-3xl flex items-center justify-center text-3xl text-emerald-400 mb-6";
                    icon.innerHTML = '<i class="fa-solid fa-shield-cat"></i>';
                    title.innerText = "상태 양호";
                    title.className = "text-2xl font-black text-emerald-400 mb-3";
                    desc.innerText = "현재 실습 대상의 생체 리듬이 정상 범위 내에 있습니다. 실시간 모니터링을 지속하십시오.";
                    action.innerText = "● 정기적인 데이터 로깅 필요 (매 2시간)";
                }
            }, 600);
        }

        window.onload = initChart;
    </script>
</body>
</html>
