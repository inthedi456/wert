            </header>

            <!-- 학년 선택 버튼 -->
            <div class="grid grid-cols-4 gap-2 md:gap-4 mb-6 md:mb-8">
                <button onclick="updateYear(1)" id="year-btn-1" class="year-btn bg-white border-2 border-blue-600 rounded-2xl p-3 md:p-5 text-center shadow-md transition-all">
