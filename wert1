    </nav>

    <!-- 메인 콘텐츠 영역 -->
    <main class="flex-1 overflow-y-auto p-4 md:p-8 bg-slate-50 pb-24 md:pb-8">
        
        <!-- ==========================================
             1. 교육 로드맵 탭
        ========================================== -->
        <section id="tab-roadmap" class="tab-content active max-w-6xl mx-auto">
            <header class="mb-6 md:mb-8">
